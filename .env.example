# Copiar a .env.local (gitignored). En producción viven en Vercel env vars.

# Resend — envío del formulario "solicitar acceso". Sin esta clave el envío
# se SIMULA (útil en dev/preview): el endpoint responde ok y solo loguea.
RESEND_API_KEY=

# Destinatario y remitente de las solicitudes (defaults en src/lib/resend.ts)
SOLICITUDES_TO_EMAIL=
SOLICITUDES_FROM_EMAIL=

# Sentry (opcional — sin DSN la observabilidad queda en logs Pino)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# URL canónica (opcional — en Vercel se deriva sola)
NEXT_PUBLIC_SITE_URL=

# ── Chat con la HV (S3) ──────────────────────────────────────────────
# Kill-switch: "false" apaga el chat por completo (el lanzador desaparece).
CHAT_ENABLED=true

# Proveedor LLM activo: groq | gemini | azure | anthropic | openai-compatible | mock
# Cambiar de proveedor = cambiar estas variables. Cero código. (ADR-003)
CHAT_PROVIDER=groq
# Modelo del proveedor activo (default por proveedor en src/lib/ia/provider.ts)
CHAT_MODEL=

# API key del proveedor activo (solo hace falta la del CHAT_PROVIDER elegido)
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
# Azure AI Foundry (demo AI-102): resource + key
AZURE_RESOURCE_NAME=
AZURE_API_KEY=
# Self-host OpenAI-compatible (ollama, vLLM, LM Studio…)
CHAT_BASE_URL=
CHAT_API_KEY=
